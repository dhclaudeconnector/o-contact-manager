# ─── Firebase ────────────────────────────────────────────────────────────────
# Bắt buộc
FIREBASE_PROJECT_ID=your-firebase-project-id

# Đường dẫn tới service account JSON (chọn 1 trong 2)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# hoặc dùng biến chuẩn của Google:
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# URL Realtime Database (tự động suy ra từ project ID nếu để trống)
# FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── API Key (dùng để tạo key lần đầu) ──────────────────────────────────────
# Không cần set ở đây — dùng: node scripts/create-api-key.js
